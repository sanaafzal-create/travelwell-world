# TravelWell.World — frontend environment (Vite)
# Copy to .env.local and fill in. Only VITE_-prefixed vars reach the browser.

# Supabase project (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ---------------------------------------------------------------------------
# Server-side only — DO NOT prefix with VITE_ and DO NOT commit real values.
# Set on the Supabase Edge Function instead:
#   supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Listed here for reference only.
# ANTHROPIC_API_KEY=sk-ant-...
